# API base URL for frontend
#
# Dev (default): leave empty — Vite proxy routes all /api/* calls to the
#   correct backend automatically (see vite.config.ts).
#
# Prod: set to the absolute origin of your FastAPI backend.
#   Express /api/orders and /api/finance/* are handled by a separate proxy
#   rule and are NOT affected by this variable.
#
# VITE_API_BASE=https://api.yourdomain.com
VITE_API_BASE=
